{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@components": ["./src/components"],
      "@features/*": ["./src/features/*"],
      "@features": ["./src/features"],
      "@layouts/*": ["./src/layouts/*"],
      "@layouts": ["./src/layouts"],
      "@pages/*": ["./src/pages/*"],
      "@pages": ["./src/pages"],
      "@store/*": ["./src/store/*"],
      "@store": ["./src/store"],
      "@styles/*": ["./src/styles/*"],
      "@styles": ["./src/styles"],
      "@utils/*": ["./src/utils/*"],
      "@utils": ["./src/utils"],
      "@types/*": ["./src/types/*"],
      "@types": ["./src/types"],
      "@i18n/*": ["./src/i18n/*"],
      "@i18n": ["./src/i18n"],
      "@data/*": ["./src/data/*"],
      "@data": ["./src/data"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
